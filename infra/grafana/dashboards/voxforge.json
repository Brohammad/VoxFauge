{
  "title": "VoxForge Voice Pipeline",
  "uid": "voxforge-main",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "E2E Turn Latency (p50)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(voxforge_e2e_turn_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 e2e"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "voxforge_active_sessions"}]
    },
    {
      "type": "stat",
      "title": "WS Connections",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "voxforge_ws_connections"}]
    },
    {
      "type": "timeseries",
      "title": "Turns Completed / Interrupted",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "rate(voxforge_turns_completed_total[5m])", "legendFormat": "completed"},
        {"expr": "rate(voxforge_turns_interrupted_total[5m])", "legendFormat": "interrupted"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider Errors",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(voxforge_provider_errors_total[5m])) by (provider, operation)",
          "legendFormat": "{{provider}}/{{operation}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool Call Rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(rate(voxforge_tool_calls_total[5m])) by (tool_name)", "legendFormat": "{{tool_name}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate Limit Blocks",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(rate(voxforge_rate_limit_blocked_total[5m])) by (category)",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Handoff Queue Depth",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "sum(voxforge_handoff_queue_depth) by (org_id)", "legendFormat": "{{org_id}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Session Consistency Operations",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "sum(rate(voxforge_session_consistency_total[5m])) by (operation, outcome)",
          "legendFormat": "{{operation}}/{{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Knowledge Ingest Jobs",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {
          "expr": "sum(rate(voxforge_knowledge_ingest_jobs_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LiveKit Room Lifecycle",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "sum(rate(voxforge_livekit_room_lifecycle_total[5m])) by (event)",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Evaluation Score (p50)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(voxforge_evaluation_score_bucket[5m]))",
          "legendFormat": "p50 score"
        }
      ]
    }
  ]
}
