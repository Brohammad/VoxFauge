DATABASE_URL=postgresql+asyncpg://voxforge:voxforge@localhost:5432/voxforge
REDIS_URL=redis://localhost:6379/0
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:8000

# Public demo (local — set DEMO_ENABLED=true to test /demo endpoints)
DEMO_ENABLED=false
DEMO_ORG_ID=a0000000-0000-4000-8000-000000000001
DEMO_USER_ID=a0000000-0000-4000-8000-000000000002
DEMO_EMAIL=demo@voxforge.io
DEMO_PASSWORD_HINT=VoxForgeDemo!

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PATHS=/api/v1/auth,/api/v1/demo

DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_TTS_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_PREFIX=vxf_
API_KEY_HASH_PEPPER=change-me-in-production
AUTH_REQUIRED=true
ORCHESTRATOR_MODE=single
MAX_AGENT_ITERATIONS=2

MEMORY_ENABLED=true
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMENSIONS=1536
MEMORY_MAX_RECENT_MESSAGES=10
MEMORY_SUMMARIZE_AFTER_MESSAGES=20
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_SIMILARITY_THRESHOLD=0.65
MEMORY_SUMMARY_MODEL=gpt-4.1-mini
TOOLS_ENABLED=true
TOOL_TIMEOUT_SECONDS=30
MAX_TOOL_ITERATIONS=5

# Customer support tools (mock providers by default)
SUPPORT_TOOLS_ENABLED=true
KNOWLEDGE_BASE_PROVIDER=mock
TICKETING_PROVIDER=mock
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

MCP_SERVERS_CONFIG=
MCP_DISCOVERY_ENABLED=true
MCP_DISCOVERY_TIMEOUT_MS=5000
MCP_STARTUP_DISCOVER=true

EVALUATION_ENABLED=true
EVALUATION_E2E_TARGET_MS=2000
EVALUATION_LLM_INPUT_COST_PER_1K=0.00015
EVALUATION_LLM_OUTPUT_COST_PER_1K=0.0006
EVALUATION_TURN_COST_BUDGET_USD=0.01
EVALUATION_HALLUCINATION_ENABLED=true
EVALUATION_JUDGE_MODEL=gpt-4.1-mini

STT_PROVIDER=deepgram
LLM_PROVIDER=openai
TTS_PROVIDER=cartesia

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=voxforge-voice
LIVEKIT_DISPATCH_ENABLED=true
LIVEKIT_RECONNECT_GRACE_SECONDS=30
