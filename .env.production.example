# Production environment — copy to .env.production and fill secrets.
# Validate: python scripts/validate_production_env.py

APP_ENV=production
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://your-domain.example
CERTBOT_EMAIL=admin@your-domain.example

# Strong secrets (generate: ./scripts/setup-production-env.sh your-domain.example)
JWT_SECRET_KEY=
API_KEY_HASH_PEPPER=
HANDOFF_REPLAY_SIGNING_SECRET=
METRICS_BEARER_TOKEN=

TRUSTED_HOSTS=your-domain.example
CORS_ORIGINS=https://your-domain.example

# Public demo (mock providers — no paid API keys required)
DEMO_ENABLED=true
DEMO_ORG_ID=a0000000-0000-4000-8000-000000000001
DEMO_USER_ID=a0000000-0000-4000-8000-000000000002
DEMO_EMAIL=demo@voxforge.io
DEMO_PASSWORD_HINT=VoxForgeDemo!

STT_PROVIDER=mock
LLM_PROVIDER=mock
TTS_PROVIDER=mock

AUTH_REQUIRED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PATHS=/api/v1/auth,/api/v1/demo

# Database (docker-compose.prod.yml overrides host for containers)
POSTGRES_USER=voxforge
POSTGRES_PASSWORD=
POSTGRES_DB=voxforge
DATABASE_URL=postgresql+asyncpg://voxforge:CHANGE_ME@postgres:5432/voxforge
REDIS_URL=redis://redis:6379/0

# Optional real providers (replace mocks when ready)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

MEMORY_ENABLED=true
KNOWLEDGE_ENABLED=true
KNOWLEDGE_CONTEXT_ENABLED=true
KNOWLEDGE_WORKER_ENABLED=true
TOOLS_ENABLED=true
EVALUATION_ENABLED=true
MCP_DISCOVERY_ENABLED=true
MCP_STARTUP_DISCOVER=true
MCP_SERVERS_CONFIG=

# LiveKit (optional — enable profile: docker compose --profile livekit)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=voxforge-voice
LIVEKIT_DISPATCH_ENABLED=true

OTEL_EXPORTER_OTLP_ENDPOINT=

# Monitoring (optional — started by deploy.sh when METRICS_BEARER_TOKEN is set)
# Grafana: SSH tunnel → ssh -L 3000:127.0.0.1:3000 root@your-vps
# Prometheus: internal only (profile monitoring)
GRAFANA_ADMIN_PASSWORD=

# Compose resource limits (optional — defaults fit 1-vCPU / 2GB droplets)
# COMPOSE_CPU_POSTGRES=0.30
# COMPOSE_CPU_REDIS=0.10
# COMPOSE_CPU_APP=0.50
# COMPOSE_CPU_NGINX=0.10
# COMPOSE_CPU_KNOWLEDGE=0.20
# COMPOSE_CPU_LIVEKIT=0.30
